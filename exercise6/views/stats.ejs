<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Market Statistics - Real Estate Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">🏠 Real Estate Dashboard</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/listings"><i class="bi bi-list"></i> Listings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/changes"><i class="bi bi-clock-history"></i> Changes</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/stats"><i class="bi bi-bar-chart"></i> Stats</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid mt-4 mb-5">
    <div class="row mb-4">
      <div class="col-md-6">
        <h1><i class="bi bi-bar-chart"></i> Market Statistics</h1>
      </div>
      <div class="col-md-6 text-end">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="refreshBtn">
          <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
      </div>
    </div>

    <!-- KPI Cards -->
    <div class="row mb-4" id="kpiCards">
      <div class="col-md-3 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <h6 class="card-title text-muted">Total Listings</h6>
            <h2 id="totalListings" class="text-primary">-</h2>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <h6 class="card-title text-muted">New (24h)</h6>
            <h2 id="newCount" class="text-success">-</h2>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <h6 class="card-title text-muted">Changed (24h)</h6>
            <h2 id="changedCount" class="text-warning">-</h2>
          </div>
        </div>
      </div>
      <div class="col-md-3 mb-3">
        <div class="card">
          <div class="card-body text-center">
            <h6 class="card-title text-muted">Removed (24h)</h6>
            <h2 id="removedCount" class="text-danger">-</h2>
          </div>
        </div>
      </div>
    </div>

    <!-- Price Statistics -->
    <div class="row mb-4">
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="card-title">Average Price</h6>
            <h3 id="avgPrice" class="text-info">-</h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="card-title">Minimum Price</h6>
            <h3 id="minPrice" class="text-success">-</h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="card-title">Maximum Price</h6>
            <h3 id="maxPrice" class="text-danger">-</h3>
          </div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="card">
          <div class="card-body">
            <h6 class="card-title">Price Spread</h6>
            <h3 id="priceSpread" class="text-secondary">-</h3>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts -->
    <div class="row">
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Price Distribution</h5>
          </div>
          <div class="card-body">
            <canvas id="histogramChart"></canvas>
          </div>
        </div>
      </div>
      <div class="col-md-6">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Recent Changes (24h)</h5>
          </div>
          <div class="card-body">
            <canvas id="changesChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>

  <footer class="bg-dark text-light mt-5 py-4 fixed-bottom w-100">
    <div class="container-fluid text-center small">
      <span id="footer-status">Loading status...</span>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
  <script src="/js/common.js"></script>
  <script src="/js/stats.js"></script>
</body>
</html>
