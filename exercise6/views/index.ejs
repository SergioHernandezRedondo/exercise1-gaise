<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Real Estate Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">🏠 Real Estate Dashboard</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link active" href="/listings"><i class="bi bi-list"></i> Listings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/changes"><i class="bi bi-clock-history"></i> Changes</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/stats"><i class="bi bi-bar-chart"></i> Stats</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid mt-5">
    <div class="row">
      <div class="col-md-8 mx-auto text-center">
        <div class="mb-5">
          <h1 class="display-4 mb-3">🏠 Real Estate Dashboard</h1>
          <p class="lead text-muted">Monitor property listings, track changes, and analyze market trends in real-time</p>
        </div>

        <!-- Quick Stats -->
        <div class="row mb-5" id="quickStats">
          <div class="col-md-3 mb-3">
            <div class="card bg-light">
              <div class="card-body">
                <h6 class="card-title text-muted"><i class="bi bi-house"></i> Total Listings</h6>
                <h2 id="totalListings" class="text-primary">-</h2>
              </div>
            </div>
          </div>
          <div class="col-md-3 mb-3">
            <div class="card bg-light">
              <div class="card-body">
                <h6 class="card-title text-muted"><i class="bi bi-currency-euro"></i> Avg Price</h6>
                <h2 id="avgPrice" class="text-success">-</h2>
              </div>
            </div>
          </div>
          <div class="col-md-3 mb-3">
            <div class="card bg-light">
              <div class="card-body">
                <h6 class="card-title text-muted"><i class="bi bi-arrow-left-right"></i> Price Range</h6>
                <h5 id="priceRange" class="text-info">-</h5>
              </div>
            </div>
          </div>
          <div class="col-md-3 mb-3">
            <div class="card bg-light">
              <div class="card-body">
                <h6 class="card-title text-muted"><i class="bi bi-clock"></i> Last Update</h6>
                <small id="lastUpdated" class="text-secondary">Never</small>
              </div>
            </div>
          </div>
        </div>

        <!-- Navigation Cards -->
        <div class="row">
          <div class="col-md-4 mb-3">
            <a href="/listings" class="text-decoration-none">
              <div class="card card-hover h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                  <i class="bi bi-list" style="font-size: 3rem; color: #0d6efd;"></i>
                  <h5 class="card-title mt-3">📋 Current Listings</h5>
                  <p class="card-text text-muted small">Browse all active property listings with sorting and filtering</p>
                </div>
              </div>
            </a>
          </div>

          <div class="col-md-4 mb-3">
            <a href="/changes" class="text-decoration-none">
              <div class="card card-hover h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                  <i class="bi bi-clock-history" style="font-size: 3rem; color: #ffc107;"></i>
                  <h5 class="card-title mt-3">📝 Change Log</h5>
                  <p class="card-text text-muted small">View recent changes and price updates with detailed diffs</p>
                </div>
              </div>
            </a>
          </div>

          <div class="col-md-4 mb-3">
            <a href="/stats" class="text-decoration-none">
              <div class="card card-hover h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                  <i class="bi bi-bar-chart" style="font-size: 3rem; color: #198754;"></i>
                  <h5 class="card-title mt-3">📊 Statistics</h5>
                  <p class="card-text text-muted small">Analyze market trends with price distributions and charts</p>
                </div>
              </div>
            </a>
          </div>
        </div>

        <!-- Info Section -->
        <div class="alert alert-info mt-5" role="alert">
          <i class="bi bi-info-circle"></i>
          <strong>Dashboard updated in real-time</strong> from your Turso database. 
          Refresh to see the latest changes from your scraper.
        </div>
      </div>
    </div>
  </div>

  <footer class="bg-dark text-light mt-5 py-4 fixed-bottom w-100">
    <div class="container-fluid text-center small">
      <span id="footer-status">Loading status...</span>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/common.js"></script>
  <script>
    // Load dashboard stats on home page
    document.addEventListener('DOMContentLoaded', async () => {
      const result = await apiFetch('/stats');
      if (result.success && result.data) {
        const data = result.data;
        document.getElementById('totalListings').textContent = data.totalListings || 0;
        document.getElementById('avgPrice').textContent = formatPrice(data.prices.average);
        document.getElementById('priceRange').textContent = 
          `${formatPrice(data.prices.min)} - ${formatPrice(data.prices.max)}`;
        
        const lastUpdated = new Date().toLocaleTimeString('de-ES');
        document.getElementById('lastUpdated').textContent = lastUpdated;
      }
    });
  </script>
</body>
</html>
