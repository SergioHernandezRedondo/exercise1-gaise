<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Real Estate Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">🏠 Real Estate Dashboard</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link <%= navActive === 'listings' ? 'active' : '' %>" href="/listings">📋 Listings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive === 'changes' ? 'active' : '' %>" href="/changes">📝 Changes</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive === 'stats' ? 'active' : '' %>" href="/stats">📊 Stats</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid mt-4">
    <h1 class="mb-4"><%= title %></h1>
    <%- body %>
  </div>

  <footer class="bg-dark text-light mt-5 py-4">
    <div class="container-fluid text-center">
      <p class="mb-0">Real Estate Monitor | <span id="last-update">Loading...</span></p>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/common.js"></script>
  <%- typeof pageScript !== 'undefined' ? `<script src="${pageScript}"><\/script>` : '' %>
</body>
</html>
