<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Change Log - Real Estate Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">🏠 Real Estate Dashboard</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/listings"><i class="bi bi-list"></i> Listings</a>
          </li>
          <li class="nav-item">
            <a class="nav-link active" href="/changes"><i class="bi bi-clock-history"></i> Changes</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/stats"><i class="bi bi-bar-chart"></i> Stats</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container-fluid mt-4 mb-5">
    <div class="row mb-4">
      <div class="col-md-6">
        <h1><i class="bi bi-clock-history"></i> Change Log</h1>
      </div>
      <div class="col-md-6 text-end">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="refreshBtn">
          <i class="bi bi-arrow-clockwise"></i> Refresh
        </button>
      </div>
    </div>

    <!-- Change Filters -->
    <div class="row mb-4">
      <div class="col-md-12">
        <div class="btn-group btn-group-sm" role="group">
          <input type="radio" class="btn-check" name="changeType" id="filterAll" value="all" checked>
          <label class="btn btn-outline-primary" for="filterAll">All</label>
          
          <input type="radio" class="btn-check" name="changeType" id="filterNew" value="new">
          <label class="btn btn-outline-success" for="filterNew"><i class="bi bi-star"></i> New</label>
          
          <input type="radio" class="btn-check" name="changeType" id="filterChanged" value="attributes_changed">
          <label class="btn btn-outline-warning" for="filterChanged"><i class="bi bi-pencil"></i> Modified</label>
          
          <input type="radio" class="btn-check" name="changeType" id="filterRemoved" value="removed">
          <label class="btn btn-outline-danger" for="filterRemoved"><i class="bi bi-trash"></i> Removed</label>
        </div>
      </div>
    </div>

    <!-- Changes Timeline -->
    <div id="changesList">
      <div class="text-center text-muted mt-5">
        <i class="bi bi-hourglass-split"></i> Loading changes...
      </div>
    </div>
  </div>

  <footer class="bg-dark text-light mt-5 py-4 fixed-bottom w-100">
    <div class="container-fluid text-center small">
      <span id="footer-status">Loading status...</span>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/changes.js"></script>
</body>
</html>
