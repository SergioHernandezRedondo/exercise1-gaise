# Milestone 2: Turso Cloud Database
# Get these from your Turso dashboard at https://turso.tech
TURSO_DB_URL=libsql://your-db-name.turso.io
TURSO_DB_TOKEN=your_auth_token_here

# Milestone 4: Telegram Notifications
ENABLE_NOTIFICATIONS=true
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Milestone 5: Scheduling
# Cron expression for automatic periodic scraping (default: every 30 minutes)
# Examples:
#   "*/15 * * * *"     - every 15 minutes (minimal safe interval for shared sites)
#   "*/30 * * * *"     - every 30 minutes
#   "0 */2 * * *"      - every 2 hours
#   "0 0 * * *"        - daily at midnight
SCRAPE_CRON=*/30 * * * *
